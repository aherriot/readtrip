# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
# In production, set these in the Vercel project's Environment Variables instead.

# --- Neon (serverless Postgres) ---
# Pooled connection (PgBouncer) — used by the running app. Note the "-pooler" host.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/curio?sslmode=require&pgbouncer=true"
# Direct connection — used by `prisma migrate`. Same host WITHOUT "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/curio?sslmode=require"

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Auth.js (NextAuth) ---
# Generate with: npx auth secret
AUTH_SECRET="replace-me"
