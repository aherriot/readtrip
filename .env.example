# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
# In production, set these in the Vercel project's Environment Variables instead.

# --- Neon (serverless Postgres) ---
# Pooled connection (PgBouncer) — used by the running app. Note the "-pooler" host.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/readtrip?sslmode=require&pgbouncer=true"
# Direct connection — used by `drizzle-kit` migrations. Same host WITHOUT "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/readtrip?sslmode=require"

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Auth.js (NextAuth) ---
# Generate with: npx auth secret
AUTH_SECRET="replace-me"

# Email magic-link (parent sign-in). In development these can be omitted — the
# sign-in link is logged to the server console and a dev-only credentials form is
# shown, so no email infra is needed locally. In production, set both to send
# real magic-link emails over SMTP.
#   EMAIL_SERVER: an SMTP connection string or nodemailer transport URL.
#   EMAIL_FROM:   the From: address shown on the sign-in email.
EMAIL_SERVER="smtp://USER:PASSWORD@smtp.example.com:587"
EMAIL_FROM="ReadTrip <login@readtrip.app>"
