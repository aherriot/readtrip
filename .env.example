# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
# In production, set these in the Vercel project's Environment Variables instead.

# --- Neon (serverless Postgres) ---
# Pooled connection (PgBouncer) — used by the running app. Note the "-pooler" host.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/readtrip?sslmode=require&pgbouncer=true"
# Direct connection — used by `drizzle-kit` migrations. Same host WITHOUT "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/readtrip?sslmode=require"

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Auth.js (NextAuth) ---
# Generate with: npx auth secret
AUTH_SECRET="replace-me"

# Email magic-link (parent sign-in) via Resend — https://resend.com.
# In development these can be omitted: the sign-in link is logged to the server
# console and a dev-only credentials form is shown, so no email infra is needed.
# In production AUTH_RESEND_KEY is required (sign-in throws without it).
#   AUTH_RESEND_KEY: a Resend API key (starts with "re_").
#   EMAIL_FROM:      the From: address. Use a sender on a domain you've verified
#                    in Resend; "onboarding@resend.dev" works to your own account
#                    email without domain verification.
AUTH_RESEND_KEY="re_..."
EMAIL_FROM="ReadTrip <onboarding@resend.dev>"
